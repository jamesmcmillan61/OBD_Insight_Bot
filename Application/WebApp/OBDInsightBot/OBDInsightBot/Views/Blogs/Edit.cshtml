@model OBDInsightBot.Models.BlogPost

@{
    ViewData["Title"] = "Edit Post";
    Layout = "_ChatLayout";
}

<style>
    h1, h2, h4 { color: var(--text-primary, #ffffff); }
    hr { border-color: var(--border-color, #2a2a2a); }
    .form-control, .form-select { background-color: var(--bg-surface, #262626); color: var(--text-primary, #ffffff); border-color: var(--border-color, #2a2a2a); }
    .form-control:focus, .form-select:focus { background-color: var(--bg-surface, #262626); color: var(--text-primary, #ffffff); border-color: var(--accent-primary, #0f62fe); box-shadow: 0 0 0 2px rgba(15,98,254,0.25); }
    .form-control::placeholder { color: var(--text-subtle, #6f6f6f); }
    .form-label, .control-label { color: var(--text-secondary, #c6c6c6); display: block; margin-bottom: 0.375rem; }
    .text-muted { color: var(--text-muted, #a8a8a8) !important; }
    .text-danger { color: var(--accent-danger, #fa4d56) !important; }
    a { color: var(--accent-primary, #0f62fe); }
    a:hover { color: #6ea6ff; }
    .btn-primary { background-color: var(--accent-primary, #0f62fe); border-color: var(--accent-primary, #0f62fe); }
    .btn-primary:hover { background-color: #0353e9; border-color: #0353e9; }
    .form-check-label { color: var(--text-secondary, #c6c6c6); }
</style>

<h1>Edit Post</h1>

<h4>BlogPost</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit" asp-route-id="@Model.Id">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" value="@Model.Id"/>

            <div class="form-group">
                <label asp-for="WrittenAt" class="control-label"></label>
                <input asp-for="WrittenAt" class="form-control" />
                <span asp-validation-for="WrittenAt" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Title" class="control-label"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="MiniDescription" class="control-label"></label>
                <input asp-for="MiniDescription" class="form-control" />
                <span asp-validation-for="MiniDescription" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Content" class="control-label"></label>
                <input asp-for="Content" class="form-control" />
                <span asp-validation-for="Content" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="PostedAt" class="control-label"></label>
                <input asp-for="PostedAt" class="form-control" />
                <span asp-validation-for="PostedAt" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="IsHidden" /> @Html.DisplayNameFor(model => model.IsHidden)
                </label>
            </div>
            <div class="form-group">
                <label asp-for="PathForFeaturedImage" class="control-label"></label>
                <input asp-for="PathForFeaturedImage" class="form-control" />
                <span asp-validation-for="PathForFeaturedImage" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
    <a asp-action="Details" asp-route-id="@Model.Id"> Edit blog</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
