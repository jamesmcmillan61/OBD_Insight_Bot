@{
    ViewData["Title"] = "Blog Admin";
    Layout = "_ChatLayout";
}

<style>
    h1, h2, h4 { color: var(--text-primary, #ffffff); }
    hr { border-color: var(--border-color, #2a2a2a); }
    a { color: var(--accent-primary, #0f62fe); }
    a:hover { color: #6ea6ff; }
    .table { color: var(--text-primary, #ffffff); border-color: var(--border-color, #2a2a2a); }
    .table thead th { color: var(--text-muted, #a8a8a8); border-bottom-color: var(--border-color, #2a2a2a); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; background-color: var(--bg-elevated, #1a1a1a); }
    .table td { border-color: var(--border-color, #2a2a2a); vertical-align: middle; background-color: var(--bg-secondary, #161616); }
    .table tbody tr:hover td { background-color: rgba(255,255,255,0.03); }
    .btn-primary { background-color: var(--accent-primary, #0f62fe); border-color: var(--accent-primary, #0f62fe); }
    .btn-primary:hover { background-color: #0353e9; border-color: #0353e9; }
</style>


@{
    // Analytics
    List<SingleUse> uses = ViewBag.single as List<SingleUse> ?? new List<SingleUse>();
    var now = DateTime.Now;
    var last24h = uses.Where(x => x.startTime >= now.AddHours(-24)).ToList();

    int sessionsLast24h = last24h.Count;
    int totalChats = uses.Sum(x => x.UserChatCount);
    int failedResponses = uses.Sum(x => x.ResponceErrors);
    int successfulUploads = uses.Count(x => x.UploadFileSucsessfully);
    int failedUploads = uses.Count(x => !x.UploadFileSucsessfully);
}


<!-- Inights TABLE -->
<div class="card-premium mt-4 p-4">
<section class="d-block d-md-flex justify-content-between">
        <h3 class="text-subheading mb-3">Session Data</h3>

        <a asp-controller="Analytics" asp-action="Index" class="btn" style="color: white;"><span style="color: white;">View insights -> </span> </a>
</section>

    <section>
        <div class="row mt-4">

            <div class="col-md-3">
                <div class="card-premium stat-item">
                    <div class="stat-number">@sessionsLast24h</div>
                    <div class="stat-label">Sessions (Last 24h)</div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card-premium stat-item">
                    <div class="stat-number">@totalChats</div>
                    <div class="stat-label">Total Chats</div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card-premium stat-item">
                    <div class="stat-number stat-number-danger">@failedResponses</div>
                    <div class="stat-label">Failed Responses</div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card-premium stat-item">
                    <div class="stat-number stat-number-success">@successfulUploads</div>
                    <div class="stat-label">Uploads Success / Fail</div>
                    <div class="text-muted">@successfulUploads / @failedUploads</div>
                </div>
            </div>

        </div>

    </section>
</div>


@{

    // Blogs
    var listOfBlogs = ViewBag.posts as List<BlogPost> ?? new List<BlogPost>();

    // Pick the most recent post by PostedAt; null if none exist
    BlogPost? latestPost = listOfBlogs
        .OrderByDescending(p => p.PostedAt)
        .FirstOrDefault();

}


<!-- Blogs TABLE -->
<div class="card-premium mt-4 p-4">
    <section class="d-block d-md-flex justify-content-between">
        <h3 class="text-subheading mb-3">Blog's</h3>

        <a asp-action="ControlBlogs" class="btn" style="color: white;"><span style="color: white;">Manage posts -> </span> </a>
    </section>

    <section>
        <div class="row mt-4">

            <div class="col-md-6">
                <div class="card-premium stat-item">
                    <div class="stat-number">@listOfBlogs.Count()</div>
                    <div class="stat-label">Visible blog posts</div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card-premium stat-item">
                    @if (latestPost != null)
                    {
                        <div class="stat-number">@latestPost.PostedAt.ToString("dd MMM yyyy")</div>
                    <div class="stat-label">last post</div>
                    }

                </div>
            </div>

            <section class="mt-3">

                <table class="table  mt-3" style="color: white;">
                    <thead>
                        <tr>
                            <th>Headline</th>
                            <th>Posted at</th>
                            <th>Visible</th>
                            <th></th>
                            
                        </tr>
                    </thead>
                    <tbody>
                        @if (listOfBlogs != null && listOfBlogs.Any())
                        {
                            foreach (var item in listOfBlogs)
                            {
                                <tr>
                                    <td>@item.Title</td>
                                    <td>@item.PostedAt.ToString("dd MMM yyyy")</td>
                                    <td>
                                        @if(item.IsHidden)
                                        {
                                            <span class="text-danger">Hidden</span>

                                        }
                                        else
                                        {
                                            <span class="text-success">Visible</span>

                                        }
                                        
                                    </td>
                                    <td class="text-end">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn" style="color: white;"><span style="color: white;">Update -> </span> </a>
                                    </td>
                                    
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted">No analytics data available.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            
            </section>

        </div>

    </section>
</div>


