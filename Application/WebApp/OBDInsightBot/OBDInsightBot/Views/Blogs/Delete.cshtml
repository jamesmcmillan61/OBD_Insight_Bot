@model OBDInsightBot.Models.BlogPost

@{
    ViewData["Title"] = "Delete Post";
    Layout = "_ChatLayout";
}

<style>
    h1, h3, h4 { color: var(--text-primary, #ffffff); }
    hr { border-color: var(--border-color, #2a2a2a); }
    dt { color: var(--text-muted, #a8a8a8); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.04em; font-weight: 600; }
    dd { color: var(--text-primary, #ffffff); margin-bottom: 0.75rem; }
    a { color: var(--accent-primary, #0f62fe); }
    a:hover { color: #6ea6ff; }
    .btn-danger { background-color: var(--accent-danger, #fa4d56); border-color: var(--accent-danger, #fa4d56); }
    .btn-danger:hover { background-color: #e8253d; border-color: #e8253d; }
</style>

<h1>Delete Post</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>BlogPost</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.WrittenAt)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.WrittenAt)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Title)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Title)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.MiniDescription)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.MiniDescription)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Content)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Content)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.PostedAt)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.PostedAt)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.IsHidden)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.IsHidden)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.PathForFeaturedImage)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.PathForFeaturedImage)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="Index">Back to List</a>
    </form>
</div>
