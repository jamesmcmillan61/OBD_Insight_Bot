@model BlogPost
@{
    ViewData["Title"] = Model.Title;
    Layout = "_HomeLayout";

    List<BlogItem> thisBlogItems = ViewBag.thisBlogItems as List<BlogItem> ?? new List<BlogItem>();
}

<style>
    .article-hero {
        min-height: 65vh;
        padding: 48px;
        border-radius: 18px;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        background-image:
            linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.40) 50%, rgba(0,0,0,0.15) 100%),
            url('@(Model.PathForFeaturedImage ?? "/branding/Blog/BlogImage.png")');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        color: #fff;
    }

    .article-back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.875rem;
        font-weight: 500;
        color: rgba(255,255,255,0.75);
        text-decoration: none;
        margin-bottom: 1.5rem;
        transition: color 0.15s;
    }

        .article-back-link:hover {
            color: #fff;
        }

    .article-meta {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin-bottom: 1rem;
        font-size: 0.875rem;
        color: rgba(255,255,255,0.65);
    }

    .article-meta span {
        display: flex;
        align-items: center;
        gap: 0.35rem;
    }

    .article-hero h1 {
        font-weight: 900;
        font-size: clamp(1.75rem, 4vw, 2.75rem);
        line-height: 1.15;
        margin-bottom: 0.75rem;
    }

    .article-hero p.lead {
        font-size: 1.0625rem;
        color: rgba(255,255,255,0.80);
        max-width: 65ch;
        margin-bottom: 0;
    }

    /* Article body */
    .article-body {
        max-width: 72ch;
        margin: 0 auto;
        padding: 3rem 1rem 4rem;
    }

    .article-body p {
        font-size: 1.0625rem;
        line-height: 1.8;
        color: var(--text-secondary, #a8a8a8);
        margin-bottom: 1.5rem;
    }

    .article-body h1,
    .article-body h2,
    .article-body h3,
    .article-body h4,
    .article-body h5,
    .article-body h6 {
        font-weight: 700;
        line-height: 1.25;
        margin-top: 2.5rem;
        margin-bottom: 0.75rem;
        color: var(--text-primary, #fff);
    }

    .article-body h1 { font-size: 2rem; }
    .article-body h2 { font-size: 1.625rem; }
    .article-body h3 { font-size: 1.375rem; }
    .article-body h4 { font-size: 1.125rem; }
    .article-body h5 { font-size: 1rem; }
    .article-body h6 { font-size: 0.9375rem; }

    .article-body img {
        width: 100%;
        height: auto;
        border-radius: 12px;
        margin: 2rem 0;
        display: block;
    }

    .article-body div {
        margin-bottom: 1.25rem;
        line-height: 1.8;
        color: var(--text-secondary, #a8a8a8);
    }

    .article-divider {
        border: none;
        border-top: 1px solid var(--border-color, #2a2a2a);
        margin: 2.5rem 0;
    }

    .article-empty {
        text-align: center;
        padding: 4rem 1rem;
        color: var(--text-secondary, #a8a8a8);
        font-size: 1rem;
    }

    /* CTA section */
    .article-cta {
        border-top: 1px solid var(--border-color, #2a2a2a);
        padding: 3rem 1rem;
        text-align: center;
    }

    /* Light theme */
    [data-theme="light"] .article-body p,
    [data-theme="light"] .article-body div {
        color: var(--text-secondary);
    }

    [data-theme="light"] .article-body h1,
    [data-theme="light"] .article-body h2,
    [data-theme="light"] .article-body h3,
    [data-theme="light"] .article-body h4,
    [data-theme="light"] .article-body h5,
    [data-theme="light"] .article-body h6 {
        color: var(--text-primary);
    }

    /* Footer */
    .footer-section {
        border-top: 1px solid var(--border-color, #2a2a2a);
    }
</style>


<!-- HERO -->
<div class="container-fluid mb-5">
    <div class="article-hero shadow">
        <a asp-controller="Blogs" asp-action="Index" class="article-back-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8"/>
            </svg>
            Back to posts
        </a>

        <div class="article-meta">
            <span>
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5M1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4z"/>
                </svg>
                @Model.PostedAt.ToString("dd MMM yyyy")
            </span>
            <span>OBD Insight Bot</span>
        </div>

        <h1>@Model.Title</h1>
        <p class="lead">@Model.MiniDescription</p>
    </div>
</div>


<!-- ARTICLE BODY -->
<div class="container">
    @if (thisBlogItems.Count == 0)
    {
        <div class="article-empty">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="currentColor" class="mb-3 d-block mx-auto opacity-50" viewBox="0 0 16 16">
                <path d="M14.5 3a.5.5 0 0 1 .5.5v9a.5.5 0 0 1-.5.5h-13a.5.5 0 0 1-.5-.5v-9a.5.5 0 0 1 .5-.5zm-13-1A1.5 1.5 0 0 0 0 3.5v9A1.5 1.5 0 0 0 1.5 14h13a1.5 1.5 0 0 0 1.5-1.5v-9A1.5 1.5 0 0 0 14.5 2z"/>
                <path d="M3 5.5a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9a.5.5 0 0 1-.5-.5M3 8a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9A.5.5 0 0 1 3 8m0 2.5a.5.5 0 0 1 .5-.5h6a.5.5 0 0 1 0 1h-6a.5.5 0 0 1-.5-.5"/>
            </svg>
            This post has no content yet.
        </div>
    }
    else
    {
        <div class="article-body">
            @foreach (BlogItem item in thisBlogItems)
            {
                string css = item.cssCode ?? "";
                string content = item.contence ?? "";

                switch (item.type)
                {
                    case BlogItem._BlogItemType.img:
                        <img src="@content" style="@css" alt="" />
                        break;

                    case BlogItem._BlogItemType.h1:
                        <h1 style="@css">@content</h1>
                        break;

                    case BlogItem._BlogItemType.h2:
                        <h2 style="@css">@content</h2>
                        break;

                    case BlogItem._BlogItemType.h3:
                        <h3 style="@css">@content</h3>
                        break;

                    case BlogItem._BlogItemType.h4:
                        <h4 style="@css">@content</h4>
                        break;

                    case BlogItem._BlogItemType.h5:
                        <h5 style="@css">@content</h5>
                        break;

                    case BlogItem._BlogItemType.h6:
                        <h6 style="@css">@content</h6>
                        break;

                    case BlogItem._BlogItemType.div:
                        <div style="@css">@content</div>
                        break;

                    case BlogItem._BlogItemType.p:
                    default:
                        <p style="@css">@content</p>
                        break;
                }
            }
        </div>
    }

    <!-- Back CTA -->
    <div class="article-cta">
        <p class="text-body-lg mb-3" style="font-size: 0.9375rem;">Enjoyed this post? Read more from us.</p>
        <a asp-controller="Blogs" asp-action="Index" class="btn btn-premium btn-premium-outline">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-2" viewBox="0 0 16 16">
                <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8"/>
            </svg>
            All Posts
        </a>
    </div>
</div>


<!-- FOOTER -->
<footer class="container-fluid section-padding-sm bg-dark-primary footer-section mt-4">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-6 mb-3 mb-md-0">
                <div class="d-flex align-items-center">
                    <div class="feature-icon me-3" style="width: 40px; height: 40px; margin-bottom: 0;">
                        <i class="fas fa-car" style="font-size: 1rem;"></i>
                    </div>
                    <div>
                        <span class="text-white fw-semibold d-block" style="font-size: 0.875rem;">Vehicle Intelligence Platform</span>
                        <span class="text-body-lg" style="font-size: 0.8125rem;">Powered by IBM Granite AI</span>
                    </div>
                </div>
            </div>
            <div class="col-md-6 text-md-end">
                <p class="text-body-lg mb-1" style="font-size: 0.8125rem;">
                    University Of Hull CPD Project for IBM.
                </p>
                <p class="text-body-lg mb-0" style="font-size: 0.8125rem;">
                    By using this platform, you agree to our <a asp-controller="home" asp-action="Privacy" class="text-primary text-decoration-none">Terms</a>
                    and <a asp-controller="home" asp-action="Privacy" class="text-primary text-decoration-none">Privacy Policy</a>
                    <a asp-controller="Blogs" asp-action="Admin" class="text-primary text-decoration-none">Manage</a>
                </p>
            </div>
        </div>
    </div>
</footer>
