@{
    Layout = "_ChatLayout";
    ViewData["Title"] = "Unable to Continue";
}

<div class="d-flex align-items-center justify-content-center" style="min-height: calc(100vh - 200px);">
    <div class="card-premium p-5 text-center" style="max-width: 560px; width: 100%;">

        <div class="info-icon mx-auto mb-4">
            <i class="bi bi-info-lg"></i>
        </div>

        <h1 class="text-heading text-white mb-3">Unable to Continue</h1>
        <div class="accent-line accent-line-center"></div>

        <div class="text-body-lg mb-4" style="color: #c6c6c6;">
            <p class="mb-3">
                We're sorry, but you have chosen not to agree to the terms of use.
            </p>
            <p class="mb-0">
                Because this application is intended for educational purposes only and requires your acknowledgment of that fact,
                we are unable to provide access to the chat feature.
            </p>
        </div>

        <div class="d-flex flex-wrap gap-3 justify-content-center pt-3" style="border-top: 1px solid #2a2a2a;">
            <a asp-controller="Chat" asp-action="Index" class="btn btn-premium btn-premium-outline">
                <i class="bi bi-arrow-left me-2"></i>Go Back
            </a>
            <a asp-controller="Home" asp-action="Index" class="btn btn-premium btn-premium-primary">
                <i class="bi bi-house me-2"></i>Return Home
            </a>
        </div>

    </div>
</div>

<style>
    .info-icon {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background-color: rgba(15, 98, 254, 0.15);
        border: 2px solid #0f62fe;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #0f62fe;
        font-size: 2.5rem;
    }

    .accent-line-center {
        margin-left: auto;
        margin-right: auto;
    }
</style>
