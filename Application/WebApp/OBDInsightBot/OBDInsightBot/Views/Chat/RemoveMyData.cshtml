@{
    Layout = "_ChatLayout";
    ViewData["Title"] = "Data Removed";
}

<div class="d-flex align-items-center justify-content-center" style="min-height: calc(100vh - 200px);">
    <div class="card-premium p-5 text-center" style="max-width: 560px; width: 100%;">

        <div class="success-icon mx-auto mb-4">
            <i class="bi bi-check-lg"></i>
        </div>

        <h1 class="text-heading text-white mb-3">Data Removed Successfully</h1>
        <div class="accent-line accent-line-center"></div>

        <p class="text-body-lg mb-4" style="color: #c6c6c6;">
            Your uploaded file, chat history, and vehicle data have been securely deleted from our system.
        </p>

        <a asp-controller="Chat" asp-action="Index" class="btn btn-premium btn-premium-primary">
            <i class="bi bi-chat-dots me-2"></i>Start a New Chat
        </a>

    </div>
</div>

<style>
    .success-icon {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background-color: rgba(36, 161, 72, 0.15);
        border: 2px solid #24a148;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #24a148;
        font-size: 2.5rem;
    }

    .accent-line-center {
        margin-left: auto;
        margin-right: auto;
    }
</style>
