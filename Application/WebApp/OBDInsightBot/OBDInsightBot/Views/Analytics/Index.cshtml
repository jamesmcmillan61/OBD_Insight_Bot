@model List<SingleUse>
@{
    Layout = "_ChatLayout";

    var now = DateTime.Now;
    var last24h = Model.Where(x => x.startTime >= now.AddHours(-24)).ToList();

    int sessionsLast24h = last24h.Count;
    int totalChats = Model.Sum(x => x.UserChatCount);
    int failedResponses = Model.Sum(x => x.ResponceErrors);
    int successfulUploads = Model.Count(x => x.UploadFileSucsessfully);
    int failedUploads = Model.Count(x => !x.UploadFileSucsessfully);
}


<!-- heading-->
<section class="d-block d-md-flex justify-content-between">
    <h1 class="text-heading">Analytics</h1>

    <a asp-controller="Analytics" asp-action="Topics" class="btn" style="color: white;"><span style="color: white;">Topic insights -> </span> </a>
</section>



<!-- Stats Row -->
<div class="row mt-4">

    <div class="col-md-3">
        <div class="card-premium stat-item">
            <div class="stat-number">@sessionsLast24h</div>
            <div class="stat-label">Sessions (Last 24h)</div>
        </div>
        </div>

        <div class="col-md-3">
            <div class="card-premium stat-item">
                <div class="stat-number">@totalChats</div>
                <div class="stat-label">Total Chats</div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card-premium stat-item">
                <div class="stat-number stat-number-danger">@failedResponses</div>
                <div class="stat-label">Failed Responses</div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card-premium stat-item">
                <div class="stat-number stat-number-success">@successfulUploads</div>
                <div class="stat-label">Uploads Success / Fail</div>
                <div class="text-muted">@successfulUploads / @failedUploads</div>
            </div>
        </div>

    </div>

    <h3 class="text-subheading mt-5">Usage Over Time</h3>
    <div class="card-premium p-4">
        <canvas id="usageChart" height="80"></canvas>
    </div>

</section>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        const labels = [
            @foreach (var item in Model)
            {
                    @Html.Raw($"\"{item.startTime:yyyy-MM-dd HH:mm}\",")
            }
        ];

        const sessionCounts = [
            @foreach (var item in Model)
            {
                    @Html.Raw("1,")
            }
        ];

        const chats = [
            @foreach (var item in Model)
            {
                    @Html.Raw(item.UserChatCount + ",")
            }
        ];

        const errors = [
            @foreach (var item in Model)
            {
                    @Html.Raw(item.ResponceErrors + ",")
            }
        ];

        const ctx = document.getElementById('usageChart');

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [
                    {
                        label: 'Sessions',
                        data: sessionCounts,
                        borderColor: '#0f62fe',
                        borderWidth: 2
                    },
                    {
                        label: 'Chats',
                        data: chats,
                        borderColor: '#24a148',
                        borderWidth: 2
                    },
                    {
                        label: 'Errors',
                        data: errors,
                        borderColor: '#fa4d56',
                        borderWidth: 2
                    }
                ]
            },
            options: {
                responsive: true,
                backgroundColor: "transparent",
                scales: {
                    x: {
                        ticks: { color: "#c6c6c6", autoSkip: true, maxTicksLimit: 10 },
                        grid: { color: "rgba(255,255,255,0.05)" }
                    },
                    y: {
                        ticks: { color: "#c6c6c6" },
                        grid: { color: "rgba(255,255,255,0.05)" }
                    }
                }
            }
        });
    </script>
}

<!-- DATA TABLE -->
<div class="card-premium mt-4 p-4">
    <h3 class="text-subheading mb-3">Session Data</h3>

    <table class="table table-dark table-striped mt-3">
        <thead>
            <tr>
                <th>ID</th>
                <th>Start Time</th>
                <th>Data Uploaded</th>
                <th>User Chat Count</th>
                <th>Pre-Built Questions</th>
                <th>Response Errors</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.startTime.ToString("g")</td>
                        <td>
                            @if (item.UploadFileSucsessfully)
                            {
                                <span class="text-success">Successful</span>
                            }
                            else
                            {
                                <span class="text-danger">Not Uploaded</span>
                            }
                        </td>
                        <td>@item.UserChatCount</td>
                        <td>@item.PreBuiltQuestions</td>
                        <td>@item.ResponceErrors</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center text-muted">No analytics data available.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
