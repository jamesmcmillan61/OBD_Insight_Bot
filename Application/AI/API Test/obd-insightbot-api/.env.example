# OBD InsightBot API Environment Variables
# ==========================================
# Copy this file to .env and modify as needed

# Environment
ENVIRONMENT=development
# ENVIRONMENT=production

# Logging
LOG_LEVEL=info
# LOG_LEVEL=debug

# Session Management
MAX_SESSIONS=1000

# CORS Origins (comma-separated)
# CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# Model Configuration (only if using LLM)
# MODEL_REPO=ibm-granite/granite-4.0-h-1b-GGUF
# MODEL_FILE=granite-4.0-h-1b-Q3_K_S.gguf
# MODEL_CONTEXT_SIZE=1024
# MODEL_THREADS=4
